{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "lib": ["esnext"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "./src",
    "paths": {
      "@features": ["features"],
      "@features/*": ["features/*"],
      "@type/*": ["types/*"],
      "@child-processes/*": ["child-processes/*"],
      "@utils": ["utils"],
      "@utils/*": ["utils/*"],
      "@configs/*": ["configs/*"],
      "@constants/*": ["constants/*"],
      "@crons/*": ["crons/*"],
      "@middlewares": ["middlewares"],
      "@middlewares/*": ["middlewares/*"],
      "@protocols/*": ["protocols/*"],
      "@schemas/*": ["schemas/*"],
      "@workers/*": ["workers/*"],
      "@services/*": ["services/*"],
      "@lib": ["lib"],
      "@lib/*": ["lib/*"],
      "@docs/*": ["../docs/*"]
    },
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*", "docs/swagger.ts", "_prisma/admin.schema.prisma"],
  "exclude": ["node_modules", "dist", "_prisma"]
}
