{
    "name": "express-app",
    "version": "1.0.0",
    "description": "Express.js application with comprehensive tooling",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon --exec ts-node src/server.ts",
        "dev:watch": "nodemon --watch src --exec ts-node src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:cluster": "node dist/cluster.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage --coverageDirectory=src/coverage",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.540.0",
        "@aws-sdk/lib-storage": "^3.540.0",
        "@aws-sdk/s3-request-presigner": "^3.540.0",
        "@prisma/adapter-pg": "^5.8.0",
        "@prisma/client": "^7.7.0",
        "axios": "^1.14.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.73.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-sse": "^1.0.0",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "moment": "^2.30.1",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.5",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "sharp": "^0.33.5",
        "socket.io": "^4.6.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "winston": "^3.11.0",
        "wkhtmltopdf": "^0.4.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/ioredis": "^4.28.10",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/nodemailer": "^6.4.14",
        "@types/passport": "^1.0.16",
        "@types/passport-jwt": "^4.0.0",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^6.0.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "concurrently": "^8.2.2",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "prisma": "^6.19.3",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "authentication",
        "socketio",
        "swagger"
    ],
    "author": "Your Name",
    "license": "MIT"
}
