    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24.14.1",
        "pnpm": ">=10.33.0"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "authentication",
        "socketio",
        "swagger"
    ],
    "author": "Your Name",
    "license": "MIT"
}
