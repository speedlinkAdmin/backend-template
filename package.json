{
    "name": "express-app",
    "version": "1.0.0",
    "description": "Express.js application with comprehensive tooling",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon --exec \"tsx\" src/server.ts",
        "dev:watch": "nodemon --watch src --exec \"tsx\" src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:cluster": "node dist/cluster.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage --coverageDirectory=src/coverage",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.540.0",
