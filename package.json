        "@types/express": "^4.17.21",
        "@types/express-serve-static-core": "5.1.1",
        "@types/ioredis": "^4.28.10",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.14",
        "@types/passport": "^1.0.16",
        "@types/passport-facebook": "3.0.4",
