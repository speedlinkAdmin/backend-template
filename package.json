        "@aws-sdk/s3-request-presigner": "^3.540.0",
        "@prisma/adapter-pg": "7.7.0",
        "@prisma/client": "7.7.0",
        "axios": "^1.14.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.73.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-sse": "^1.0.0",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "jsx-email": "2.8.4",
        "moment": "^2.30.1",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "passport": "^0.7.0",
        "passport-facebook": "3.0.0",
        "passport-google-oauth20": "2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-email": "5.2.10",
        "resend": "6.11.0",
        "sharp": "^0.33.5",
        "socket.io": "^4.6.1",
