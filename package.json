        "concurrently": "^8.2.2",
        "eslint": "^9.0.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "prisma": "7.7.0",
        "supertest": "^7.1.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "tsx": "4.21.0",
        "typescript": "^5.3.3"
