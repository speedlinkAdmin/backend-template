{
    "name": "express-app",
    "version": "1.0.0",
    "description": "Express.js application with comprehensive tooling",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon --exec ts-node src/server.ts",
        "dev:watch": "nodemon --watch src --exec ts-node src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:cluster": "node dist/cluster.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage --coverageDirectory=src/coverage",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1030.0",
        "@aws-sdk/lib-storage": "^3.1030.0",
        "@aws-sdk/s3-request-presigner": "^3.1030.0",
        "@prisma/adapter-pg": "7.7.0",
        "@prisma/client": "7.7.0",
        "axios": "^1.15.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.73.5",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "express-rate-limit": "^7.5.1",
        "express-sse": "^1.0.0",
        "helmet": "^7.2.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "jsx-email": "2.8.4",
        "moment": "^2.30.1",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.5",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.20.0",
        "resend": "6.11.0",
        "sharp": "^0.33.5",
        "socket.io": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0",
        "wkhtmltopdf": "^0.4.0",
        "zod": "^3.25.76"
